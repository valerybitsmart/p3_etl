# Priority API credentials are stored in dbo.etl_tenant_config (SQL Server)
# No API keys needed here 

# SQL Server
SQL_SERVER=your_server
SQL_DATABASE=your_bi_database
SQL_USERNAME=your_user
SQL_PASSWORD=your_password
# Set to 1 to use Windows Authentication instead of SQL auth
SQL_TRUSTED_CONNECTION=0

# WhatsApp alerts via whapi.cloud
WHAPI_TOKEN=your_whapi_channel_token
# Comma-separated list of recipients (bare number or full whapi address)
# Example: 972501234567, 972509876543
# or full format: 972501234567@s.whatsapp.net, 972509876543@s.whatsapp.net
WHAPI_RECIPIENT=972501234567, 972509876543

# ETL settings
BATCH_SIZE=1000
LOG_LEVEL=INFO
LOG_DIR=logs
